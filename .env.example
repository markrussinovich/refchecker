# RefChecker Environment Configuration
# Copy this file to .env and fill in your API keys
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your keys
#   docker compose up

# =============================================================================
# Multi-user Authentication
# Set REFCHECKER_MULTIUSER=true to enable OAuth login.
# Without this, the server runs in single-user mode (no login required).
# =============================================================================
REFCHECKER_MULTIUSER=true

# Secret key used to sign JWT session tokens (HttpOnly cookies).
# IMPORTANT: Set a long random value in production, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Public URL of the site (used for CORS and OAuth redirect URIs)
# Example: https://refchecker.example.com
SITE_URL=

# Set to "true" to mark auth cookies as Secure (required for HTTPS deployments)
HTTPS_ONLY=false

# Maximum concurrent reference checks per user (default: 3)
MAX_CHECKS_PER_USER=3

# Comma-separated email addresses that should be granted admin rights.
# The very first user to sign in is also auto-promoted to admin.
# Example: admin@example.com,owner@example.com
ADMIN_EMAILS=

# Google OAuth 2.0 credentials
# Create at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: <SITE_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Override callback URL (optional, auto-detected from request if blank)
GOOGLE_REDIRECT_URI=

# GitHub OAuth App credentials
# Create at https://github.com/settings/developers
# Callback URL: <SITE_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Override callback URL (optional, auto-detected from request if blank)
GITHUB_REDIRECT_URI=

# Microsoft (Entra ID / Azure AD) OAuth credentials
# Create at https://portal.azure.com → App registrations
# Redirect URI: <SITE_URL>/api/auth/callback/microsoft
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Override callback URL (optional, auto-detected from request if blank)
MS_REDIRECT_URI=

# =============================================================================
# LLM Provider API Keys
# Note: In multi-user mode, API keys are stored in the browser (localStorage)
# and sent per-request. They are never persisted on the server.
# =============================================================================

# Anthropic Claude API Key
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API Key  
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google AI (Gemini) API Key
# Get yours at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# =============================================================================
# Optional API Keys
# =============================================================================

# Semantic Scholar API Key (optional)
# For higher rate limits when verifying references
# Get yours at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# HuggingFace Token (for GPU variant with gated models)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# =============================================================================
# Advanced Configuration
# =============================================================================

# Data directory inside container (default: /app/data)
# REFCHECKER_DATA_DIR=/app/data

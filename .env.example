# RefChecker Environment Configuration
# Copy this file to .env and fill in your API keys
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your keys
#   docker compose up

# =============================================================================
# Multi-user Authentication (optional)
# Set AUTH_ENABLED=true to require sign-in via Google or GitHub OAuth.
# When disabled (default) the app runs in single-user mode with no login.
# =============================================================================

# Enable multi-user authentication
AUTH_ENABLED=false

# Secret key used to sign JWT session tokens.
# IMPORTANT: Set a long random value in production, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Google OAuth 2.0 credentials
# Create at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: <your-host>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Override callback URL (optional, auto-detected from request if blank)
GOOGLE_REDIRECT_URI=

# GitHub OAuth App credentials
# Create at https://github.com/settings/developers
# Callback URL: <your-host>/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Override callback URL (optional, auto-detected from request if blank)
GITHUB_REDIRECT_URI=

# URL prefix the browser should land on after OAuth completes (default: /)
# Only needed when the frontend is served at a non-root path.
FRONTEND_REDIRECT_BASE=

# =============================================================================
# LLM Provider API Keys
# At least one is required for reference verification
# =============================================================================

# Anthropic Claude API Key
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API Key  
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google AI (Gemini) API Key
# Get yours at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# =============================================================================
# Optional API Keys
# =============================================================================

# Semantic Scholar API Key (optional)
# For higher rate limits when verifying references
# Get yours at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# HuggingFace Token (for GPU variant with gated models)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# =============================================================================
# Advanced Configuration
# =============================================================================

# Data directory inside container (default: /app/data)
# REFCHECKER_DATA_DIR=/app/data

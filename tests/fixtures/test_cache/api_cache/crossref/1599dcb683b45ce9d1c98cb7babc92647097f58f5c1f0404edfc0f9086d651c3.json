", "content-type": "application/pdf", "content-version": "vor", "intended-application": "text-mining"}, {"URL": "https://link.springer.com/article/10.1007/s11033-025-10278-9", "content-type": "text/html", "content-version": "vor", "intended-application": "text-mining"}, {"URL": "https://link.springer.com/content/pdf/10.1007/s11033-025-10278-9.pdf", "content-type": "application/pdf", "content-version": "vor", "intended-application": "similarity-checking"}], "URL": "https://doi.org/10.1007/s11033-025-10278-9", "published": {"date-parts": [[2025, 2, 4]]}}, {"publisher": "Elsevier BV", "DOI": "10.1016/j.smim.2025.102004", "type": "journal-article", "title": ["HBV antigen as a tumour antigen in adoptive TCR-T cell therapy for HBV-related HCC: rationale and clinical effectiveness"], "author": [{"given": "Shan", "family": "He", "sequence": "first", "affiliation": []}, {"given": "Anthony T.", "family": "Tan", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0002-2942-0485", "authenticated-orcid": false, "given": "Antonio", "family": "Bertoletti", "sequence": "additional", "affiliation": []}], "container-title": ["Seminars in Immunology"], "link": [{"URL": "https://api.elsevier.com/content/article/PII:S1044532325000764?httpAccept=text/xml", "content-type": "text/xml", "content-version": "vor", "intended-application": "text-mining"}, {"URL": "https://api.elsevier.com/content/article/PII:S1044532325000764?httpAccept=text/plain", "content-type": "text/plain", "content-version": "vor", "intended-application": "text-mining"}], "URL": "https://doi.org/10.1016/j.smim.2025.102004", "published": {"date-parts": [[2025, 12]]}}]
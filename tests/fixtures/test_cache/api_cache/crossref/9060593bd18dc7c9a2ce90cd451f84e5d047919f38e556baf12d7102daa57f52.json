[{"publisher": "Worldwide Protein Data Bank", "DOI": "10.2210/pdb9q9l/pdb", "type": "dataset", "title": ["HSV-1 prefusion glycoprotein B"], "author": [{"given": "B.", "family": "Vollmer", "sequence": "first", "affiliation": []}, {"given": "T.", "family": "Mulvaney", "sequence": "additional", "affiliation": []}, {"given": "H.", "family": "Ebel", "sequence": "additional", "affiliation": []}, {"given": "J.", "family": "Nentwig", "sequence": "additional", "affiliation": []}, {"given": "K.", "family": "Gruenewald", "sequence": "additional", "affiliation": []}], "container-title": ["Worldwide Protein Data Bank"], "URL": "https://doi.org/10.2210/pdb9q9l/pdb", "published": {"date-parts": [[2025, 2, 26]]}}, {"publisher": "Worldwide Protein Data Bank", "DOI": "10.2210/pdb9q9n/pdb", "type": "dataset", "title": ["HSV-1 prefusion glycoprotein B bound by Nb1_gbHSV"], "author": [{"given": "B.", "family": "Vollmer", "sequence": "first", "affiliation": []}, {"given": "T.", "family": "Mulvaney", "sequence": "additional", "affiliation": []}, {"given": "H.", "family": "Ebel", "sequence": "additional", "affiliation": []}, {"given": "J.", "family": "Nentwig", "sequence": "additional", "affiliation": []}, {"given": "K.", "family": "Gruenewald", "sequence": "additional", "affiliation": []}], "container-title": ["Worldwide Protein Data Bank"], "URL": "https://doi.org/10.2210/pdb9q9n/pdb", "published": {"date-parts": [[2025, 2, 26]]}}, {"publisher": "Worldwide Protein Data Bank", "DOI": "10.2210/pdb9q9s/pdb", "type": "dataset", "title": ["HSV-2 prefusion glycoprotein B bound by Nb1_gbHSV"], "author": [{"given": "B.", "family": "Vollmer", "sequence": "first", "affiliation": []}, {"given": "T.", "family": "Mulvaney", "sequence": "additional", "affiliation": []}, {"given": "H.", "family": "Ebel", "sequence": "additional", "affiliation": []}, {"given": "J.", "family": "Nentwig", "sequence": "additional", "affiliation": []}, {"given": "K.", "family": "Gruenewald", "sequence": "additional", "affiliation": []}], "container-title": ["Worldwide Protein Data Bank"], "URL": "https://doi.org/10.2210/pdb9q9s/pdb", "published": {"date-parts": [[2025, 2, 26]]}}, {"publisher": "Worldwide Protein Data Bank", "DOI": "10.2210/pdb9uea/pdb", "type": "dataset", "title": ["Prefusion structure of GX2012 spike glycoprotein"], "author": [{"given": "X.", "family": "Wang", "sequence": "first", "affiliation": []}, {"given": "Z.", "family": "Lin", "sequence": "additional", "affiliation": []}], "container-title": ["Worldwide Protein Data Bank"], "URL": "https://doi.org/10.2210/pdb9uea/pdb", "published": {"date-parts": [[2025, 4, 8]]}}, {"publisher": "Springer Science and Business Media LLC", "abstract": "<jats:title>Abstract</jats:title>\n                  <jats:p>Glycoprotein B (gB) refolds between prefusion and postfusion conformations to facilitate herpesvirus entry into host cells. However, the isolation of prefusion-specific neutralizing antibodies, effective against other viral entry machines, has been challenging. Here we describe stabilization of the prefusion gB ectodomain from herpes simplex virus 1 (HSV-1), determine ectodomain structures at 2.9- to 4.1-Å resolution using cryogenic electron microscopy (cryo-EM) and isolate a prefusion-specific gB-neutralizing antibody termed WS.HSV-1.24. Murine immunization with gB stabilized in the prefusion conformation induced high titres of antibodies binding to both prefusion and postfusion gB, but—most notably—without measurable serum neutralization. Accessibility analysis revealed iso-surface exposure, with accessible surfaces on prefusion HSV-1 gB also exposed on postfusion gB. Structural analysis suggested substantial plasticity, with regions that refolded between pre- and postfusion conformations relegated to domain interfaces with limited accessibility; indeed, WS.HSV-1.24 recognized a domain-interface refolding region to facilitate neutralization. We propose that prefusion HSV-1 gB evades neutralization by most antibodies through an iso-surface display that is coupled to structural plasticity.</jats:p>", "DOI": "10.1038/s41564-025-02153-x", "type": "journal-article", "title": ["Prefusion structure, evasion and neutralization of HSV-1 glycoprotein B"], "author": [{"given": "Ryan S.", "family": "Roark", "sequence": "first", "affiliation": []}, {"given": "Andrew J.", "family": "Schaub", "sequence": "additional", "affiliation": []}, {"given": "Wei", "family": "Shi", "sequence": "additional", "affiliation": []}, {"given": "Maple", "family": "Wang", "sequence": "additional", "affiliation": []}, {"given": "Fabiana A.", "family": "Bahna", "sequence": "additional", "affiliation": []}, {"given": "Jordan E.", "family": "Becker", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0001-7405-3373", "authenticated-orcid": false, "given": "Andrea", "family": "Biju", "sequence": "additional", "affiliation": []}, {"given": "Sue", "family": "Chong", "sequence": "additional", "affiliation": []}, {"given": "Haijuan", "family": "Du", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0001-5357-660X", "authenticated-orcid": false, "given": "Yicheng", "family": "Guo", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0009-0007-8657-5479", "authenticated-orcid": false, "given": "Hsiang", "family": "Hong", "sequence": "additional", "affiliation": []}, {"given": "Phinikoula S.", "family": "Katsamba", "sequence": "additional", "affiliation": []}, {"given": "Seetha M.", "family": "Mannepalli", "sequence": "additional", "affiliation": []}, {"given": "Adam S.", "family": "Olia", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0001-5653-8684", "authenticated-orcid": false, "given": "Li", "family": "Ou", "sequence": "additional", "affiliation": []}, {"given": "Sarah K.", "family": "Rubin", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0002-4973-8247", "authenticated-orcid":
[{"publisher": "Oxford University Press (OUP)", "abstract": "<jats:title>Summary</jats:title><jats:p>Warping is an approach to the reduction and analysis of phase variability in functional observations, by applying a smooth bijection to the function argument. We propose a natural representation of warping functions in terms of a new type of elementary functions named ‘warping component functions’, or ‘warplets’, which are combined into the warping function by composition. The inverse warping function is trivial and explicit to obtain. A sequential Bayesian estimation strategy is introduced which fits a series of models and transfers the posterior of the previous fit into the prior of the next fit. Model selection is based on a warping analogue to wavelet thresholding, combined with Bayesian inference.</jats:p>", "DOI": "10.1111/j.1467-9868.2010.00752.x", "type": "journal-article", "title": ["A Multiresolution Approach to Time Warping Achieved by a Bayesian Prior–Posterior Transfer Fitting Strategy"], "author": [{"given": "Gerda", "family": "Claeskens", "sequence": "first", "affiliation": [{"name": "Katholieke Universiteit Leuven , Belgium"}]}, {"given": "Bernard W.", "family": "Silverman", "sequence": "additional", "affiliation": [{"name": "University of Oxford , UK"}]}, {"given": "Leen", "family": "Slaets", "sequence": "additional", "affiliation": [{"name": "Katholieke Universiteit Leuven , Belgium"}]}], "container-title": ["Journal of the Royal Statistical Society Series B: Statistical Methodology"], "link": [{"URL": "https://api.wiley.com/onlinelibrary/tdm/v1/articles/10.1111%2Fj.1467-9868.2010.00752.x", "content-type": "unspecified", "content-version": "vor", "intended-application": "text-mining"}, {"URL": "https://academic.oup.com/jrsssb/article-pdf/72/5/673/49515964/jrsssb_72_5_673.pdf", "content-type": "application/pdf", "content-version": "vor", "intended-application": "syndication"}, {"URL": "https://academic.oup.com/jrsssb/article-pdf/72/5/673/49515964/jrsssb_72_5_673.pdf", "content-type": "unspecified", "content-version": "vor", "intended-application": "similarity-checking"}], "URL": "https://doi.org/10.1111/j.1467-9868.2010.00752.x", "published": {"date-parts": [[2010, 9, 14]]}}, {"publisher": "Elsevier BV", "DOI": "10.2139/ssrn.1683890", "type": "journal-article", "title": ["Warping Functional Data in R and C via a Bayesian Multiresolution Approach"], "author": [{"given": "Leen", "family": "Slaets", "sequence": "first", "affiliation": []}, {"given": "Gerda", "family": "Claeskens", "sequence": "additional", "affiliation": []}, {"given": "Bernard", "family": "Silverman", "sequence": "additional", "affiliation": []}], "container-title": ["SSRN Electronic Journal"], "URL": "https://doi.org/10.2139/ssrn.1683890", "published": {"date-parts": [[2010]]}}, {"publisher": "IEEE", "DOI": "10.1109/icmla.2010.69", "type": "proceedings-article", "title": ["Bayesian Classification of Flight Calls with a Novel Dynamic Time Warping Kernel"], "author": [{"given": "Theodoros", "family": "Damoulas", "sequence": "first", "affiliation": []}, {"given": "Samuel", "family": "Henry", "sequence": "additional", "affiliation": []}, {"given": "Andrew", "family": "Farnsworth", "sequence": "additional", "affiliation": []}, {"given": "Michael", "family": "Lanzone", "sequence": "additional", "affiliation": []}, {"given": "Carla", "family": "Gomes", "sequence": "additional", "affiliation": []}], "container-title": ["2010 Ninth International Conference on Machine Learning and Applications"], "link": [{"URL": "http://xplorestaging.ieee.org/ielx5/5707360/5708804/05708866.pdf?arnumber=5708866", "content-type": "unspecified", "content-version": "vor", "intended-application": "similarity-checking"}], "URL": "https://doi.org/10.1109/icmla.2010.69", "published": {"date-parts": [[2010, 12]]}}, {"publisher": "Allerton Press", "DOI": "10.3103/s1066530710030026", "type": "journal-article", "title": ["Oracle convergence rate of posterior under projection prior a
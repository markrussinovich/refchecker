[{"publisher": "IEEE", "DOI": "10.1109/silcon59133.2023.10404195", "type": "proceedings-article", "title": ["Olive: An Instruction Following LLaMA Model For Odia Language"], "author": [{"given": "Shantipriya", "family": "Parida", "sequence": "first", "affiliation": [{"name": "Silo AI,Helsinki,Finland"}]}, {"given": "Sambit", "family": "Sekhar", "sequence": "additional", "affiliation": [{"name": "Odia Generative AI,Bhubaneswar,India"}]}, {"given": "Subhadarshi", "family": "Panda", "sequence": "additional", "affiliation": [{"name": "Odia Generative AI,Bhubaneswar,India"}]}, {"given": "Swateek", "family": "Jena", "sequence": "additional", "affiliation": [{"name": "RightSense Inc,Bangalore,India"}]}, {"given": "Abhijeet", "family": "Parida", "sequence": "additional", "affiliation": [{"name": "Odia Generative AI,Washington,USA"}]}, {"given": "Soumendra Kumar", "family": "Sahoo", "sequence": "additional", "affiliation": [{"name": "Odia Generative AI,Bangalore,India"}]}, {"given": "Satya Ranjan", "family": "Dash", "sequence": "additional", "affiliation": [{"name": "KIIT University,Bhubaneswar,India"}]}], "container-title": ["2023 IEEE Silchar Subsection Conference (SILCON)"], "link": [{"URL": "http://xplorestaging.ieee.org/ielx7/10404094/10404112/10404195.pdf?arnumber=10404195", "content-type": "unspecified", "content-version": "vor", "intended-application": "similarity-checking"}], "URL": "https://doi.org/10.1109/silcon59133.2023.10404195", "published": {"date-parts": [[2023, 11, 3]]}}, {"publisher": "Association for Computational Linguistics", "DOI": "10.18653/v1/2023.emnlp-demo.49", "type": "proceedings-article", "title": ["Video-LLaMA: An Instruction-tuned Audio-Visual Language Model for Video Understanding"], "author": [{"given": "Hang", "family": "Zhang", "sequence": "first", "affiliation": []}, {"given": "Xin", "family": "Li", "sequence": "additional", "affiliation": []}, {"given": "Lidong", "family": "Bing", "sequence": "additional", "affiliation": []}], "container-title": ["Proceedings of the 2023 Conference on Empirical Methods in Natural Language Processing: System Demonstrations"], "URL": "https://doi.org/10.18653/v1/2023.emnlp-demo.49", "published": {"date-parts": [[2023]]}}, {"publisher": "Springer Science and Business Media LLC", "abstract": "<title>Abstract</title>\n        <p>In the U.S. inpatient payment system, the Diagnosis-Related Group (DRG) is pivotal, but its assignment process is inefficient. The study introduces DRG-LLaMA, an advanced large language model (LLM) fine-tuned on clinical notes to enhance DRGs assignment. Utilizing LLaMA as the foundational model and optimizing it through Low-Rank Adaptation (LoRA) on 236,192 MIMIC-IV discharge summaries, our DRG-LLaMA-7B model exhibited a noteworthy macro-averaged F1 score of 0.327, a top-1 prediction accuracy of 52.0%, and a macro-averaged Area Under the Curve (AUC) of 0.986, with a maximum input token length of 512. This model surpassed the performance of prior leading models in DRG prediction, showing a relative improvement of 40.3% and 35.7% in macro-averaged F1 score compared to ClinicalBERT and CAML, respectively. Applied to base DRG and complication or comorbidity (CC)/major complication or comorbidity (MCC) prediction, DRG-LLaMA achieved a top-1 prediction accuracy of 67.8% and 67.5%, respectively. Additionally, our findings indicate that DRG-LLaMA's performance correlates with increased model parameters and input context lengths.</p>", "DOI": "10.21203/rs.3.rs-3397089/v1", "type": "posted-content", "title": ["DRG-LLaMA: Tuning LLaMA Model to Predict Diagnosis-related Group for Hospitalized Patients"], "author": [{"ORCID": "https://orcid.org/0000-0001-7649-0892", "authenticated-orcid": false, "given": "Hanyin", "family": "Wang", "sequence": "first", "affiliation": [{"name": "Mayo Clinic Health System"}]}, {"given": "Chufan", "family": "Gao", "sequence": "additional", "affiliation": [{"name": "University of Illinois Urbana-Champaign"}]}, {"given": "Christopher", "family": "Dantona", "sequence": "additional", "affiliation": [{"name": "Mayo Clinic"}]}, {"given": "Bryan", "family": "Hull", "sequence": "additional", "affiliation": [{"name": "Mayo Clinic"}]}, {"given": "Jimeng", "family": "Sun", "sequence": "additional", "affiliation": [{"name": "University of Illinois Urbana-Champaign"}]}], "link": [{"URL": "https://www.researchsquare.com/article/rs-3397089/v1", "content-type": "text/html", "content-version": "vor", "intended-application": "text-mining"}, {"URL": "https://www.researchsquare.com/article/rs-3397089/v1.html", "content-type": "unspecified", "content-version": "vor", "intended-application": "similarity-checking"}], "URL": "https://doi.org/10.21203/rs.3.rs-3397089/v1", "published": {"date-parts": [[2023, 10, 6]]}}, {"publisher": "Elsevier BV", "DOI": "10.1016/j.animal.2023.100800", "type": "journal-article", "title": ["Development and validation of a smart system for medullation and diameter assessment of alpaca, llama and mohair fibres"], "author": [{"given": "M.D.", "family": "Quispe", "sequence": "first", "affiliation": []}, {"given": "C.C.", "family": "Quispe", "sequence": "additional", "affiliation": []}, {"given": "L.", "family": "Serrano-Arriezu", "sequence": "additional", "affiliation": []}, {"given": "J.D.", "family": "Trigo", "sequence": "additional", "affiliation": []}, {"given": "J.J.", "family": "Bengoechea", "sequence": "additional", "affiliation": []}, {"given": "E.C.", "family": "Quispe", "sequence": "additional", "affiliation": []}], "container-title": ["animal"], "link": [{"URL": "https://api.elsevier.com/content/article/PII:S1751731123000964?httpAccept=text/xml", "content-type": "text/xml", "content-version": "vor", "intended-application": "text-mining"}, {"URL": "https://api.elsevier.com/content/article/PII:S1751731123000964?httpAccept=text/plain", "content-type": "text/plain", "content-version": "vor", "intended-application": "text-mining"}], "URL": "https://doi.org/10.1016/j.animal.2023.100800", "published": {"date-parts": [[2023, 5]]}}, {"publisher": "IEEE", "DOI": "10.1109/icercs57948.2023.10434081", "type": "proceedings-article", "title": ["Comprehensive Examination of Instruction-Based Language Models: A Comparative Analysis of Mistral-7B and Llama-2-7B"], "author": [{"given": "Hiren", "family": "Thakkar", "sequence": "first", "affiliation": [{"name": "VIT-AP University,School of Advanced Sciences,Amaravati,Andhra Pradesh"}]}, {"given": "A", "family": "Manimaran", "sequence": "additional", "affiliation": [{"name": "VIT-AP University,School of Advanced Sciences,Amaravati,Andhra Pradesh"}]}], "container-title": ["2023 International Conference on Emerging Research in Computational Science (ICERCS)"], "link": [{"URL": "http://xplorestaging.ieee.org/ielx7/10433896/10433898/10434081.pdf?arnumber=10434081", "content-type": "unspecified", "content-version": "vor", "intended-application": "similarity-checking"}], "URL": "https://doi.org/10.1109/icercs57948.2023.10434081", "published": {"date-parts": [[2023, 12, 7]]}}]
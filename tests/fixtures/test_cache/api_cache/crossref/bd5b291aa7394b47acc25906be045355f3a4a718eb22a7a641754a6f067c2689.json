[{"publisher": "Springer Science and Business Media LLC", "DOI": "10.1038/s41467-025-65890-x", "type": "journal-article", "title": ["Author Correction: A single residue in the yellow fever virus envelope protein modulates virion architecture and antigenicity"], "author": [{"ORCID": "https://orcid.org/0000-0002-5747-7657", "authenticated-orcid": false, "given": "Summa", "family": "Bibby", "sequence": "first", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0001-6830-8165", "authenticated-orcid": false, "given": "James", "family": "Jung", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0001-9583-0282", "authenticated-orcid": false, "given": "Yu Shang", "family": "Low", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0002-6640-3377", "authenticated-orcid": false, "given": "Alberto A.", "family": "Amarilla", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0002-5617-8639", "authenticated-orcid": false, "given": "Natalee D.", "family": "Newton", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0001-9535-1863", "authenticated-orcid": false, "given": "Connor A. P.", "family": "Scott", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0009-0007-6985-9939", "authenticated-orcid": false, "given": "Jessica", "family": "Balk", "sequence": "additional", "affiliation": []}, {"given": "Yi Tian", "family": "Ting", "sequence": "additional", "affiliation": []}, {"given": "Morgan E.", "family": "Freney", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0003-3304-4715", "authenticated-orcid": false, "given": "Benjamin", "family": "Liang", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0002-4855-8703", "authenticated-orcid": false, "given": "Timothy", "family": "Grant", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0003-3380-2117", "authenticated-orcid": false, "given": "Fasséli", "family": "Coulibaly", "sequence": "additional", "affiliation": []}, {"given": "Paul", "family": "Young", "sequence": "additional", "affiliation": []}, {"given": "Roy A.", "family": "Hall", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0003-0139-9829", "authenticated-orcid": false, "given": "Jody", "family": "Hobson-Peters", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0003-3205-4970", "authenticated-orcid": false, "given": "Naphak", "family": "Modhiran", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0001-5957-2853", "authenticated-orcid": false, "given": "Daniel", "family": "Watterson", "sequence": "additional", "affiliation": []}], "container-title": ["Nature Communications"], "link": [{"URL": "https://www.nature.com/articles/s41467-025-65890-x.pdf", "content-type": "application/pdf", "content-version": "vor", "intended-application": "text-mining"}, {"URL": "https://www.nature.com/articles/s41467-025-65890-x", "content-type": "text/html", "content-version": "vor", "intended-application": "text-mining"}, {"URL": "https://www.nature.com/articles/s41467-025-65890-x.pdf", "content-type": "application/pdf", "content-version": "vor", "intended-application": "similarity-checking"}], "URL": "https://doi.org/10.1038/s41467-025-65890-x", "published": {"date-parts": [[2025, 11, 5]]}}, {"publisher": "Springer Science and Business Media LLC", "abstract": "<jats:title>Abstract</jats:title>\n                  <jats:p>\n                    Yellow fever virus (YFV) is a re-emerging flavivirus that causes severe hepatic disease and mortality in humans. Despite being researched for over a century, the structure of YFV has remained elusive. Here we use a chimeric virus platform to resolve the first high resolution cryo-EM structures of YFV. Stark differences in particle morphology and homogeneity are observed between vaccine and virulent strains of YFV, and these are found to have significant implications on antibody recognition and neutralisation. We identify a single residue (R380) in the YFV\n                    <jats:sub>17D</jats:sub>\n                    envelope protein that stabilises the virion surface, and leads to reduced exposure of the cross-reactive fusion loop epitope. The differences in virion morphology between YFV strains also contribute to the reduced sensitivity of the virulent YFV virions to vaccine-induced antibodies. These findings have significant implications for YFV biology, vaccinology and structure-based flavivirus antigen design.\n                  </jats:p>", "DOI": "10.1038/s41467-025-63038-5", "type": "journal-article", "title": ["A single residue in the yellow fever virus envelope protein modulates virion architecture and antigenicity"], "author": [{"ORCID": "https://orcid.org/0000-0002-5747-7657", "authenticated-orcid": false, "given": "Summa", "family": "Bibby", "sequence": "first", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0001-6830-8165", "authenticated-orcid": false, "given": "James", "family": "Jung", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0001-9583-0282", "authenticated-orcid": false, "given": "Yu Shang", "family": "Low", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0002-6640-3377", "authenticated-orcid": false, "given": "Alberto A.", "family": "Amarilla", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0002-5617-8639", "authenticated-orcid": false, "given": "Natalee D.", "family": "Newton", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0000-0001-9535-1863", "authenticated-orcid": false, "given": "Connor A. P.", "family": "Scott", "sequence": "additional", "affiliation": []}, {"ORCID": "https://orcid.org/0009-0007-6985-9939", "authenticated-orcid": false, "given": "Jessica", "family": "Balk", "sequence": "additio
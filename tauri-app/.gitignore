node_modules/
dist/
build/
__pycache__/
*.pyc
.venv/
venv/

# Rust / Tauri build artifacts
src-tauri/target/
# NOTE: Cargo.lock IS committed (binary app) so CI builds are reproducible.
# Leaving it un-pinned let a fresh `time 0.3.48` resolve in CI and break
# `tauri-utils` with E0119, failing the v0.9.21 release build while v0.9.20
# (which had resolved time 0.3.47) succeeded. Committing the lock pins the
# whole dependency tree to the known-good set.

# PyInstaller sidecar output (rebuilt by CI / local script)
src-tauri/binaries/
python/build/
python/dist/
python/pyi-runtime/
python/*.spec.bak

# Signing — code signing certs
*.p12
*.pfx
*.cer
*.mobileprovision
AuthKey_*.p8
.env
.env.local

# Tauri updater private key (public key lives in tauri.conf.json)
refchecker-updater.key
refchecker-updater.key.pub
*-updater.key
*-updater.key.pub

{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capability set for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "core:event:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "core:webview:allow-internal-toggle-devtools",
    "shell:default",
    "shell:allow-open",
    "dialog:default"
  ]
}
